{
  "expo": {
    "name": "Dansal",
    "slug": "dansal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "dansal",
    "userInterfaceStyle": "automatic",

    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDIcPma3nCA5so9SIFHlaM0yME8EPxQAnA"
        }
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Dansal"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f97316",
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
